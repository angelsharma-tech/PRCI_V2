# =========================================================
# PRCI v2 — Production Environment Configuration
# Phase 4.4 — Full Production Deployment & Dockerization
#
# Copy this file to .env and fill in real values before deploy.
# =========================================================

# =========================================================
# Database (PostgreSQL)
# =========================================================
POSTGRES_USER=prci
POSTGRES_PASSWORD=change_this_to_a_strong_password_32chars
POSTGRES_DB=prci_v2
DATABASE_URL=postgresql://prci:change_this_to_a_strong_password_32chars@db:5432/prci_v2

# =========================================================
# Security (CRITICAL — change these!)
# =========================================================
SECRET_KEY=change_this_to_a_very_long_random_string_min_32_chars

# =========================================================
# API Settings
# =========================================================
API_TITLE=PRCI v2 API
API_VERSION=4.4.0
API_DOCS_URL=/docs
API_ENABLE_CORS=true

# =========================================================
# Logging
# =========================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =========================================================
# Feature Flags / Development
# =========================================================
DEBUG=false
DB_ECHO=false

# =========================================================
# Frontend → Backend URL (inside Docker network use nginx)
# =========================================================
API_BASE_URL=http://nginx/api

# =========================================================
# Optional: External integrations (future)
# =========================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# S3_BUCKET=
# AWS_REGION=
